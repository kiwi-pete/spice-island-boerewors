# Spice Island Boerewors — environment variables
# Copy to .env.local for local dev, and set the same keys in Vercel for production.

# Supabase project: tapmeza (https://fzkzhnjqdtxxfctaqikp.supabase.co)
SUPABASE_URL=https://fzkzhnjqdtxxfctaqikp.supabase.co

# SECRET — service-role key (Supabase dashboard → tapmeza → Project Settings → API).
# Bypasses Row Level Security; server-only. NEVER prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# Admin PIN for the /admin editor.
ADMIN_PIN=2026

# Long random string used to sign the admin session cookie.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SESSION_SECRET=
